# ============================================
# 项目环境变量配置模板
# 拷贝此文件为 .env 并填入实际值
# ============================================

# 应用配置
APP_NAME=foods-test
APP_ENV=development
APP_PORT=3000
APP_DEBUG=true

# 数据库配置（示例）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=foods_db
DB_USER=root
DB_PASSWORD=your_password

# API 配置
API_BASE_URL=http://localhost:3000/api
API_TIMEOUT=5000

# 日志配置
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
